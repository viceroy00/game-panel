# ============================================
# Game Panel 환경 설정
# ============================================

# --- 앱 ---
APP_NAME=Game Panel
APP_URL=https://game.example.com
DEBUG=false

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_64CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- DB ---
DATABASE_URL=sqlite+aiosqlite:///./data/game_panel.db

# --- SMTP (mail.example.com) ---
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com

# --- 초기 관리자 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Docker ---
DOCKER_SOCKET=/var/run/docker.sock
GAME_NETWORK=game-servers

# --- 헬스체크 ---
HEALTHCHECK_INTERVAL_MINUTES=5
AUTO_DELETE_DAYS=7
HEALTHCHECK_NOTIFY=true

# --- Discord OAuth2 (지인 인증) ---
# https://discord.com/developers/applications 에서 앱 생성
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://game.example.com/api/auth/discord/callback
DISCORD_GUILD_ID=                    # 비공개 디스코드 서버 ID
DISCORD_BOT_TOKEN=                   # 서버 멤버 확인용 봇 토큰
DISCORD_ENABLED=true

# --- Discord 알림 채널 ---
# 서버 우클릭 → "채널 ID 복사"로 확인 (개발자 모드 필요)
DISCORD_NOTIFY_CHANNEL_ID=           # 서버 상태 알림 채널 (다운/복구/삭제)
DISCORD_REQUEST_CHANNEL_ID=          # 게임 신청 알림 (비워두면 NOTIFY 채널 사용)
DISCORD_NOTIFY_ENABLED=true

# --- Discord 역할 제한 ---
# 허용할 역할 ID (쉼표 구분). 비워두면 서버 멤버면 누구나 접근 가능.
# 역할 ID 확인: Discord 설정 → 서버 설정 → 역할 → 우클릭 → "역할 ID 복사"
# 여러 역할 중 하나라도 있으면 허용됨 (로그인+신청+제어 전체 적용)
DISCORD_ALLOWED_ROLE_IDS=            # 예: 123456789,987654321

# --- 초대 코드 (디스코드 안 쓰는 지인용) ---
INVITE_CODE_ENABLED=true

# --- 파일 관리 ---
MAX_MOD_UPLOAD_SIZE_MB=100

# --- 포트 ---
PANEL_HTTP_PORT=8090
